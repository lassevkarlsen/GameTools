@using Microsoft.AspNetCore.WebUtilities
@inject NavigationManager NavigationManager

<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8"/>
    <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
    <base href="/"/>
    <ResourcePreloader/>
    <link rel="stylesheet" href="@Assets["lib/bootstrap/dist/css/bootstrap.min.css"]"/>
    <link rel="stylesheet" href="@Assets["app.css"]"/>
    <link rel="stylesheet" href="@Assets["GameTools.styles.css"]"/>
    <RadzenTheme Theme="material" />
    <ImportMap/>
    <link rel="icon" type="image/png" href="favicon.png"/>
    <HeadOutlet @rendermode="InteractiveServer"/>
    @if (IsXeneonMode)
    {
        <style>
            :root {
                --rz-base-900: #000000;
            }
        </style>
    }
</head>

<body>
<Routes @rendermode="InteractiveServer"/>
<ReconnectModal/>
<script>
    window.gameTools = window.gameTools || {};
    window.gameTools.setBaseFontSize = function (isXeneonMode) {
        document.documentElement.style.fontSize = isXeneonMode ? '24px' : '';
    };
</script>
<script src="@Assets["js/diablo4-event-timers.js"]"></script>
<script src="@Assets["_framework/blazor.web.js"]"></script>
<script src="_content/Radzen.Blazor/Radzen.Blazor.js?v=@(typeof(Radzen.Colors).Assembly.GetName().Version)"></script>
</body>

</html>

@code {
    private bool IsXeneonMode
    {
        get
        {
            var query = QueryHelpers.ParseQuery(new Uri(NavigationManager.Uri).Query);
            return query.TryGetValue("xeneon", out var xeneonValues) && xeneonValues.Any(value => !string.IsNullOrWhiteSpace(value));
        }
    }
}