@using GameTools.Components.Pages.Diablo4.Models
@using Microsoft.AspNetCore.Components.RenderTree
@using Microsoft.AspNetCore.Mvc.Formatters
@inherits BasePage

@page "/{profileIdString}/diablo4/eventtimers"

<PageTitle>GameTools :: Diablo 4 :: Event Timers</PageTitle>

<RadzenStack Orientation="Orientation.Horizontal" Wrap="FlexWrap.Wrap" Style="margin-bottom: 1rem;" Alignment="FlexAlign.Center">
    <div>
        <RadzenCheckBox Name="chkShowLegionEvents" @bind-Value="@_showLegionEvents" Change="(bool b) => OnShowLegionEventsChanged(b)"/>
        <RadzenLabel Text="Show legion events" Component="chkShowLegionEvents"/>
    </div>

    <div>
        <RadzenCheckBox Name="chkShowHelltides" @bind-Value="@_showHelltides" Change="(bool b) => OnShowHelltidesChanged(b)"/>
        <RadzenLabel Text="Show helltides" Component="chkShowHelltides"/>
    </div>

    <div>
        <RadzenCheckBox Name="chkShowWorldBosses" @bind-Value="@_showWorldBosses" Change="(bool b) => OnShowWorldBossesChanged(b)"/>
        <RadzenLabel Text="Show world bosses" Component="chkShowWorldBosses"/>
    </div>
</RadzenStack>

@if (_events.Count > 0)
{
    int filtersEnabled = (_showHelltides ? 1 : 0) + (_showLegionEvents ? 1 : 0) + (_showWorldBosses ? 1 : 0);
    if (filtersEnabled > 0)
    {
        int helltidesLeftToDisplay = 9 / filtersEnabled;
        int legionLeftToDisplay = helltidesLeftToDisplay;
        int worldBossesLeftToDisplay = helltidesLeftToDisplay;

        <div id="d4-event-timers" class="d4-event-card-container">
            @foreach (Diablo4Event evt in _events)
            {
                if (!IsWithinDisplayWindow(evt))
                {
                    continue;
                }

                string cardClass = GetEventCardClass(evt);

                bool showEvent = evt.Type switch
                {
                    Diablo4EventType.Helltide  => _showHelltides && --helltidesLeftToDisplay >= 0,
                    Diablo4EventType.Legion    => _showLegionEvents && --legionLeftToDisplay >= 0,
                    Diablo4EventType.WorldBoss => _showWorldBosses && --worldBossesLeftToDisplay >= 0,
                    _                          => false,
                };

                if (!showEvent)
                {
                    continue;
                }

                bool hasNotification = HasNotification(evt.Key);

                <div class="@cardClass"
                     data-d4-progress-start="@evt.StartTime.ToUnixTimeMilliseconds()"
                     data-d4-progress-end="@evt.EndTime.ToUnixTimeMilliseconds()"
                     @onclick='() => ToggleNotificationAsync(evt.Type, evt.Key, evt.StartTime)'>
                    <div class="d4-event-body">
                        @if (evt.Type == Diablo4EventType.Helltide)
                        {
                            <div class="d4-event-icon d4-event-icon-helltide" aria-hidden="true">⛧</div>
                        } else if (evt.Type == Diablo4EventType.Legion) {
                            <div class="d4-event-icon d4-event-icon-legion" aria-hidden="true">&#x1f463;</div>
                        } else if (evt.Type == Diablo4EventType.WorldBoss)
                        {
                            <div class="d4-event-icon d4-event-icon-worldboss" aria-hidden="true">&#x1f464;</div>
                        }
                        <div class="d4-event-content">
                            <div class="d4-event-card-header">
                                <div>@evt.DisplayTitle</div>
                                @if (ShouldShowNotificationToggle)
                                {
                                    <button
                                        class="d4-notification-button @(hasNotification ? "d4-notification-button-on" : "d4-notification-button-off")"
                                        type="button"
                                        @onclick:stopPropagation="true"
                                        @onclick='() => ToggleNotificationAsync(evt.Type, evt.Key, evt.StartTime)'>
                                        <RadzenIcon
                                            Icon="@(hasNotification ? "notifications_active" : "notifications")"/>
                                    </button>
                                }
                            </div>
                            <div class="d4-event-time"
                                 data-d4-start-time="@evt.StartTime.ToUnixTimeMilliseconds()">@evt.StartTime.LocalDateTime.ToString("g")</div>
                        </div>
                    </div>
                    <div class="d4-event-progress" aria-hidden="true">
                        <div class="d4-event-progress-fill"></div>
                    </div>
                </div>
            }
        </div>
    }
}