@inherits LayoutComponentBase

<RadzenComponents @rendermode="InteractiveServer" />
<RadzenLayout>
    @if (!_hideHeader)
    {
        <RadzenHeader Orientation="LayoutOrientation.Horizontal">
            <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="0" JustifyContent="JustifyContent.SpaceBetween">
                <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="10px">
                    <RadzenSidebarToggle Click="@(() => _sidebarExpanded = !_sidebarExpanded)"/>
                    <div><RadzenLabel Text="Game Tools"/> :: <RadzenLabel Text="@_pageTitle"/></div>
                </RadzenStack>
                <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" JustifyContent="JustifyContent.End">
                    @if (_profileId != null)
                    {
                        <RadzenAppearanceToggle/>

                        <RadzenButton ButtonStyle="ButtonStyle.Primary" Variant="Variant.Flat" Click="NavigateToProfilePage" Icon="account_circle"/>
                        @* <RadzenIcon Icon="account_circle" Style="cursor: pointer;" @onclick="@(() => NavigateToProfilePage())" /> *@
                    }
                </RadzenStack>
            </RadzenStack>
        </RadzenHeader>
    }
    <RadzenSidebar @bind-Expanded="@_sidebarExpanded">
        <RadzenPanelMenu>
            @if (!_hideHeader)
            {
                @if (_profileId != null)
                {
                    <RadzenPanelMenuItem Text="Home" Icon="home" Path="@($"/{_profileId}/{_parameters}")"/>
                }
                else
                {
                    <RadzenPanelMenuItem Text="Home" Icon="home" Path="/"/>
                }
            }
            @if (_profileId != null)
            {
                <RadzenPanelMenuItem Text="General Tools" Icon="service_toolbox">
                    <RadzenPanelMenuItem Text="Timers" Icon="timer" Path="@($"/{_profileId}/timers{_parameters}")"/>
                    <RadzenPanelMenuItem Text="Shopping List" Icon="shopping_cart" Path="@($"/{_profileId}/shopping{_parameters}")"/>
                </RadzenPanelMenuItem>

                <RadzenPanelMenuItem Text="Enshrouded" Icon="stadia_controller">
                    <RadzenPanelMenuItem Text="Upgrade Gems" Icon="diamond" Path="@($"/{_profileId}/enshrouded/gems{_parameters}")"/>
                </RadzenPanelMenuItem>

                @* <RadzenPanelMenuItem Text="No Man's Sky" Icon="rocket_launch"> *@
                @*     <RadzenPanelMenuItem Text="Guilds Rewards" Icon="diamond_shine" Path="@($"/{_profileId}/nms/guildrewards")"/> *@
                @* </RadzenPanelMenuItem> *@
                <RadzenPanelMenuItem Text="No Man's Sky" Icon="rocket_launch">
                    <RadzenPanelMenuItem Text="Portal Addresses" Icon="diamond_shine" Path="@($"/{_profileId}/nms/portaladdresses{_parameters}")"/>
                </RadzenPanelMenuItem>

                <RadzenPanelMenuItem Text="Diablo 4" Icon="counter_4">
                    <RadzenPanelMenuItem Text="Event Timers" Icon="timer" Path="@($"/{_profileId}/diablo4/eventtimers{_parameters}")"/>
                </RadzenPanelMenuItem>
            }
        </RadzenPanelMenu>
    </RadzenSidebar>
    <RadzenBody>
        <div class="rz-p-1">
            <CascadingValue Value="(Action<string>)SetPageTitle">
                <CascadingValue Value="(Action<Guid>)SetProfileId">
                    @Body
                </CascadingValue>
            </CascadingValue>
        </div>
    </RadzenBody>
</RadzenLayout>

<div id="blazor-error-ui" data-nosnippet>
    An unhandled error has occurred.
    <a href="." class="reload">Reload</a>
    <span class="dismiss">🗙</span>
</div>